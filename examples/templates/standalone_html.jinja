      const elRun = document.getElementById('runBtn')
      const elCsv = document.getElementById('csvBtn')
      const elStatus = document.getElementById('status')
      const elSeries = document.getElementById('seriesSelect')
      const elGrid = document.getElementById('grid')
      const elAxes = document.getElementById('axes')
      const elLine = document.getElementById('line')
      const elPlotLabel = document.getElementById('plotLabel')

      // Apply solver-provided default simulation parameters, if present
      try {
        const d = simulateModel?.simDefaults || null
        if (d && typeof d === 'object') {
          if (typeof d.t0 === 'number') elT0.value = String(d.t0)
          if (typeof d.tf === 'number') elTf.value = String(d.tf)
          if (typeof d.dt === 'number') elDt.value = String(d.dt)
        }
      } catch {
        /* empty */
      }

      // Fill solver options textarea from schema defaults (if present)
      try {
        const schema = simulateModel?.optionsSchema || null
        const props = schema?.properties || {}
        const defaults = {}
        for (const k of Object.keys(props)) {
          if (props?.[k] && Object.prototype.hasOwnProperty.call(props[k], 'default')) {
            defaults[k] = props[k].default
          }
        }
        elSolverOpts.value = JSON.stringify(defaults, null, 2)
      } catch {
        elSolverOpts.value = '{}'
      }

      let lastResult = null

      function setStatus(msg, kind) {
        elStatus.textContent = msg
        elStatus.classList.remove('good')
        elStatus.classList.remove('bad')
        if (kind === 'good') elStatus.classList.add('good')
        if (kind === 'bad') elStatus.classList.add('bad')
      }

      function escapeCsv(s) {
        const v = String(s)
        if (v.includes(',') || v.includes('\n') || v.includes('\r') || v.includes('"')) {
          return '"' + v.replaceAll('"', '""') + '"'
        }
        return v
      }

      function toWideCsv(result) {
        const t = result?.data?.t || []
        const x = result?.data?.x || {}
        const y = result?.data?.y || {}
        const u = result?.data?.u || {}
        const c = result?.data?.c || result?.data?.z || {}

        const series = []
        const add = (prefix, obj) => {
          for (const k of Object.keys(obj || {}).sort()) {
            series.push({ key: prefix + k, values: obj[k] || [] })
          }
        }
        add('x.', x)
        add('y.', y)
        add('u.', u)
        add('c.', c)

        const header = ['t'].concat(series.map((s) => formatSeriesLabel(s.key)))
        const lines = [header.map(escapeCsv).join(',')]

        const n = t.length
        for (let i = 0; i < n; i++) {
          const row = [t[i]]
          for (const s of series) row.push(s.values[i])
          lines.push(row.map(escapeCsv).join(','))
        }

        return lines.join('\n')
      }

      function downloadText(filename, content, mime) {
        const blob = new Blob([content], { type: mime || 'text/plain;charset=utf-8' })
        const url = URL.createObjectURL(blob)
        const a = document.createElement('a')
        a.href = url
        a.download = filename
        a.click()
        setTimeout(() => URL.revokeObjectURL(url), 500)
      }

      function buildSeriesOptions(result, preferredKey) {
        while (elSeries.firstChild) elSeries.removeChild(elSeries.firstChild)

        const keys = []
        const addGroup = (prefix, obj) => {
          if (!obj) return
          for (const k of Object.keys(obj)) keys.push(prefix + k)
        }

        addGroup('x.', result?.data?.x)
        addGroup('y.', result?.data?.y)
        addGroup('u.', result?.data?.u)
        addGroup('c.', result?.data?.c)
        addGroup('z.', result?.data?.z)

        keys.sort()

        for (const k of keys) {
          const opt = document.createElement('option')
          opt.value = k
          opt.textContent = formatSeriesLabel(k)
          elSeries.appendChild(opt)
        }

        const nextSelection =
          keys.length === 0 ? '' : keys.includes(String(preferredKey || '')) ? preferredKey : keys[0]

        if (nextSelection) elSeries.value = nextSelection
        return String(nextSelection || '')
      }

      function getSeries(result, key) {
        const t = result?.data?.t || []
        const [grp, ...rest] = String(key || '').split('.')
        const name = rest.join('.')
        const group = result?.data?.[grp] || null
        const y = group?.[name] || []
        return { t, y }
      }

      function getMetaVariableUnit(group, name) {
        const vars = Array.isArray(group) ? group : []
        for (const v of vars) {
          if (!v || typeof v !== 'object') continue
          if (String(v.name || '') !== name) continue
          const unit = String(v.unit || '').trim()
          if (unit) return unit
        }
        return ''
      }

      function getSeriesUnit(key) {
        const [grp, ...rest] = String(key || '').split('.')
        const name = rest.join('.')
        if (!name) return ''
        if (grp === 'x') return getMetaVariableUnit(model?.meta?.states, name)
        if (grp === 'y') return getMetaVariableUnit(model?.meta?.algebraics, name)
        if (grp === 'u') return getMetaVariableUnit(model?.meta?.inputs, name)
        if (grp === 'c' || grp === 'z') return ''
        return ''
      }

      function formatSeriesLabel(key) {
        const k = String(key || '')
        const unit = getSeriesUnit(k)
        return unit ? `${k} [${unit}]` : k
      }

      const PLOT = {
        width: 1000,
        height: 420,
        marginLeft: 72,
        marginRight: 20,
        marginTop: 46,
        marginBottom: 56,
      }

      function makeSvg(name) {
        return document.createElementNS('http://www.w3.org/2000/svg', name)
      }

      function formatTick(v) {
        const n = Number(v)
        if (!Number.isFinite(n)) return ''
        if (Math.abs(n) >= 1000 || (Math.abs(n) > 0 && Math.abs(n) < 0.01)) return n.toExponential(2)
        return String(Number(n.toFixed(4)))
      }

      function drawGrid() {
        while (elGrid.firstChild) elGrid.removeChild(elGrid.firstChild)
        const plotW = PLOT.width - PLOT.marginLeft - PLOT.marginRight
        const plotH = PLOT.height - PLOT.marginTop - PLOT.marginBottom
        const nx = 10
        const ny = 6
        for (let i = 1; i < nx; i++) {
          const x = PLOT.marginLeft + (i * plotW) / nx
          const ln = makeSvg('line')
          ln.setAttribute('x1', String(x))
          ln.setAttribute('x2', String(x))
          ln.setAttribute('y1', String(PLOT.marginTop))
          ln.setAttribute('y2', String(PLOT.marginTop + plotH))
          ln.setAttribute('stroke', '#1a263b')
          ln.setAttribute('stroke-width', '1')
          elGrid.appendChild(ln)
        }
        for (let j = 1; j < ny; j++) {
          const y = PLOT.marginTop + (j * plotH) / ny
          const ln = makeSvg('line')
          ln.setAttribute('x1', String(PLOT.marginLeft))
          ln.setAttribute('x2', String(PLOT.marginLeft + plotW))
          ln.setAttribute('y1', String(y))
          ln.setAttribute('y2', String(y))
          ln.setAttribute('stroke', '#1a263b')
          ln.setAttribute('stroke-width', '1')
          elGrid.appendChild(ln)
        }
      }

      function drawAxes(tMin, tMax, yMin, yMax, seriesLabel) {
        while (elAxes.firstChild) elAxes.removeChild(elAxes.firstChild)
        const plotW = PLOT.width - PLOT.marginLeft - PLOT.marginRight
        const plotH = PLOT.height - PLOT.marginTop - PLOT.marginBottom
        const x0 = PLOT.marginLeft
        const x1 = PLOT.marginLeft + plotW
        const y0 = PLOT.marginTop
        const y1 = PLOT.marginTop + plotH

        const xAxis = makeSvg('line')
        xAxis.setAttribute('x1', String(x0))
        xAxis.setAttribute('x2', String(x1))
        xAxis.setAttribute('y1', String(y1))
        xAxis.setAttribute('y2', String(y1))
        xAxis.setAttribute('stroke', '#9bb0d1')
        xAxis.setAttribute('stroke-width', '1.5')
        elAxes.appendChild(xAxis)

        const yAxis = makeSvg('line')
        yAxis.setAttribute('x1', String(x0))
        yAxis.setAttribute('x2', String(x0))
        yAxis.setAttribute('y1', String(y0))
        yAxis.setAttribute('y2', String(y1))
        yAxis.setAttribute('stroke', '#9bb0d1')
        yAxis.setAttribute('stroke-width', '1.5')
        elAxes.appendChild(yAxis)

        const tickCount = 5
        for (let i = 0; i <= tickCount; i++) {
          const frac = i / tickCount
          const x = x0 + frac * plotW
          const y = y1 - frac * plotH

          const xTick = makeSvg('line')
          xTick.setAttribute('x1', String(x))
          xTick.setAttribute('x2', String(x))
          xTick.setAttribute('y1', String(y1))
          xTick.setAttribute('y2', String(y1 + 6))
          xTick.setAttribute('stroke', '#9bb0d1')
          xTick.setAttribute('stroke-width', '1')
          elAxes.appendChild(xTick)

          const yTick = makeSvg('line')
          yTick.setAttribute('x1', String(x0 - 6))
          yTick.setAttribute('x2', String(x0))
          yTick.setAttribute('y1', String(y))
          yTick.setAttribute('y2', String(y))
          yTick.setAttribute('stroke', '#9bb0d1')
          yTick.setAttribute('stroke-width', '1')
          elAxes.appendChild(yTick)

          const xText = makeSvg('text')
          xText.setAttribute('x', String(x))
          xText.setAttribute('y', String(y1 + 22))
          xText.setAttribute('fill', '#9bb0d1')
          xText.setAttribute('font-size', '11')
          xText.setAttribute('text-anchor', 'middle')
          xText.textContent = formatTick(tMin + frac * (tMax - tMin))
          elAxes.appendChild(xText)

          const yText = makeSvg('text')
          yText.setAttribute('x', String(x0 - 10))
          yText.setAttribute('y', String(y + 4))
          yText.setAttribute('fill', '#9bb0d1')
          yText.setAttribute('font-size', '11')
          yText.setAttribute('text-anchor', 'end')
          yText.textContent = formatTick(yMin + frac * (yMax - yMin))
          elAxes.appendChild(yText)
        }

        const title = makeSvg('text')
        title.setAttribute('x', String((x0 + x1) / 2))
        title.setAttribute('y', '24')
        title.setAttribute('fill', '#e7eefc')
        title.setAttribute('font-size', '16')
        title.setAttribute('font-weight', '700')
        title.setAttribute('text-anchor', 'middle')
        title.textContent = seriesLabel ? `Plot: ${seriesLabel}` : 'Plot'
        elAxes.appendChild(title)

        const xLabel = makeSvg('text')
        xLabel.setAttribute('x', String((x0 + x1) / 2))
        xLabel.setAttribute('y', String(PLOT.height - 14))
        xLabel.setAttribute('fill', '#9bb0d1')
        xLabel.setAttribute('font-size', '12')
        xLabel.setAttribute('text-anchor', 'middle')
        xLabel.textContent = 'Time (t)'
        elAxes.appendChild(xLabel)

        const yLabel = makeSvg('text')
        yLabel.setAttribute('x', '18')
        yLabel.setAttribute('y', String((y0 + y1) / 2))
        yLabel.setAttribute('fill', '#9bb0d1')
        yLabel.setAttribute('font-size', '12')
        yLabel.setAttribute('text-anchor', 'middle')
        yLabel.setAttribute('transform', `rotate(-90 18 ${(y0 + y1) / 2})`)
        yLabel.textContent = seriesLabel || 'Value'
        elAxes.appendChild(yLabel)
      }

      function plotSeries(t, y, label) {
        const plotW = PLOT.width - PLOT.marginLeft - PLOT.marginRight
        const plotH = PLOT.height - PLOT.marginTop - PLOT.marginBottom

        if (!Array.isArray(t) || !Array.isArray(y) || t.length === 0 || y.length === 0) {
          elLine.setAttribute('points', '')
          drawAxes(0, 1, 0, 1, label || '')
          elPlotLabel.textContent = label || ''
          return
        }

        const n = Math.min(t.length, y.length)

        let tMin = Infinity,
          tMax = -Infinity
        let yMin = Infinity,
          yMax = -Infinity
        for (let i = 0; i < n; i++) {
          const ti = Number(t[i])
          const yi = Number(y[i])
          if (!Number.isFinite(ti) || !Number.isFinite(yi)) continue
          tMin = Math.min(tMin, ti)
          tMax = Math.max(tMax, ti)
          yMin = Math.min(yMin, yi)
          yMax = Math.max(yMax, yi)
        }
        if (
          !Number.isFinite(tMin) ||
          !Number.isFinite(tMax) ||
          !Number.isFinite(yMin) ||
          !Number.isFinite(yMax)
        ) {
          elLine.setAttribute('points', '')
          drawAxes(0, 1, 0, 1, label || '')
          elPlotLabel.textContent = label || ''
          return
        }
        if (tMax === tMin) tMax = tMin + 1
        if (yMax === yMin) yMax = yMin + 1

        drawAxes(tMin, tMax, yMin, yMax, label || '')

        const pts = []
        for (let i = 0; i < n; i++) {
          const ti = Number(t[i])
          const yi = Number(y[i])
          if (!Number.isFinite(ti) || !Number.isFinite(yi)) continue
          const xx = PLOT.marginLeft + ((ti - tMin) / (tMax - tMin)) * plotW
          const yy = PLOT.marginTop + plotH - ((yi - yMin) / (yMax - yMin)) * plotH
          pts.push(xx.toFixed(2) + ',' + yy.toFixed(2))
        }
        elLine.setAttribute('points', pts.join(' '))
        elPlotLabel.textContent = String(label || '')
      }

      function makeFuFromTextarea() {
        const body = String(elInputFn.value || '')
        // eslint-disable-next-line no-new-func
        const fn = new Function('t', body)
        return (t) => {
          let out = fn(t)
          if (out == null) {
            if (nu === 0) return []
            throw new Error('f_u must return an array')
          }
          if (!Array.isArray(out)) {
            if (nu === 1 && typeof out === 'number' && Number.isFinite(out)) return [out]
            throw new Error('f_u must return an array')
          }
          if (out.length !== nu) {
            if (!(nu === 0 && out.length === 0)) {
              throw new Error(`Expected ${nu} inputs but got ${out.length}`)
            }
          }
          return out
        }
      }

      function run() {
        elRun.disabled = true
        elCsv.disabled = true
        setStatus('Running...', '')

        try {
          const t0 = Number(elT0.value)
          const tf = Number(elTf.value)
          const dt = Number(elDt.value)

          if (!Number.isFinite(t0) || !Number.isFinite(tf) || !Number.isFinite(dt)) {
            throw new Error('t0 tf dt must be finite numbers')
          }
          if (dt <= 0) throw new Error('dt must be > 0')
          if (tf <= t0) throw new Error('tf must be > t0')

          const f_u = makeFuFromTextarea()

          let solverOptions = {}
          try {
            solverOptions = JSON.parse(String(elSolverOpts.value || '{}'))
          } catch {
            throw new Error('Solver options JSON is not valid JSON')
          }

          const params = { sim: { t0, tf, dt, f_u, solverOptions } }
          const context = { source: 'ui_template', compiledAt: new Date().toISOString() }

          const result = simulateModel(params, context, model)
          lastResult = result

          const previousSeries = elSeries.value
          const sel = buildSeriesOptions(result, previousSeries)
          const s = getSeries(result, sel)
          plotSeries(s.t, s.y, formatSeriesLabel(sel))

          elCsv.disabled = false
          setStatus('Simulation complete.', 'good')
        } catch (e) {
          console.error(e)
          setStatus(String(e?.message || e), 'bad')
        } finally {
          elRun.disabled = false
        }
      }

      elRun.addEventListener('click', run)
      elSeries.addEventListener('change', () => {
        if (!lastResult) return
        const sel = elSeries.value
        const s = getSeries(lastResult, sel)
        plotSeries(s.t, s.y, formatSeriesLabel(sel))
      })

      elCsv.addEventListener('click', () => {
        if (!lastResult) return
        const csv = toWideCsv(lastResult)
        const stamp = new Date().toISOString().replaceAll(':', '-').replaceAll('.', '-')
        downloadText(`simulation_${stamp}.csv`, csv, 'text/csv;charset=utf-8')
      })

      drawGrid()
      drawAxes(0, 1, 0, 1, '')
      setStatus('Ready.', '')
    </script>
  
<script>
(() => {
  const marker = '__RUMOCA_SERIES_PERSIST__'
  if (window[marker]) return
  window[marker] = true

  const select = document.getElementById('seriesSelect')
  const runBtn = document.getElementById('runBtn')
  if (!(select instanceof HTMLSelectElement) || !(runBtn instanceof HTMLElement)) return

  let preferred = String(select.value || '')

  const selectOption = (key) => {
    if (!key) return false
    for (let i = 0; i < select.options.length; i++) {
      if (select.options[i]?.value === key) {
        if (select.value !== key) {
          select.value = key
          select.dispatchEvent(new Event('change'))
        }
        preferred = key
        return true
      }
    }
    return false
  }

  select.addEventListener('change', () => {
    preferred = String(select.value || '')
  })

  const observer = new MutationObserver(() => {
    if (preferred) selectOption(preferred)
  })
  observer.observe(select, { childList: true })

  runBtn.addEventListener('click', () => {
    const current = String(select.value || preferred || '')
    if (current) preferred = current
  })
})()
</script>
</body>
</html>
