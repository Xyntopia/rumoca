  {%- endfor %}

  {%- for (name, comp) in cp_map|items %}
    var {{ js_ident(name) }} = constants["{{ name }}"];
  {%- endfor %}

  {%- for (name, comp) in x_map|items %}
    var {{ js_ident(name) }} = xVec[{{ loop.index0 }}];
